# Database configuration
# Set POSTGRES_USER, POSTGRES_PASSWORD, POSTGRES_DB to match your database settings
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=transactions_db
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/transactions_db

# Redis connection string (used as Celery broker & backend)
REDIS_URL=redis://redis:6379/0

# Gemini API Key (obtained from Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here

# CORS setup (comma-separated list of origins, or * for all)
ALLOWED_ORIGINS=*

# Local directory where raw uploaded files are cached
UPLOAD_DIR=uploads
